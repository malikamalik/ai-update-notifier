{
  "crons": [
    { "path": "/api/cron/daily-news", "schedule": "0 8 * * *" }
  ],
  "functions": {
    "api/cron/daily-news.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

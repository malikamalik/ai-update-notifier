{
  "crons": [
    { "path": "/api/cron/daily-news", "schedule": "0 4 * * *" },
    { "path": "/api/cron/daily-news", "schedule": "0 16 * * *" }
  ],
  "functions": {
    "api/cron/daily-news.js": { "maxDuration": 60 },
    "api/news.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
